{
  "rules": {
    "users": {
      "$uid": {
        ".read": "$uid === auth.uid || auth.token.email === $uid",
        ".write": "$uid === auth.uid || auth.token.email === $uid",
        ".validate": "newData.hasChildren(['name','email'])"
      }
    },
    "messages": {
      "$conversationId": {
        ".read": "auth != null",
        ".write": "auth != null",
        "$messageId": {
          ".read": "auth != null",
          ".write": "auth != null",
          ".validate": "newData.hasChildren(['sender','content','createdAt','conversationId'])"
        }
      }
    },
    "conversations": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$conversationId": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['type','participants','createdAt'])",
        "participants": {
          "$userId": {
            ".read": "auth != null",
            ".write": "auth != null"
          }
        }
      }
    },
    "typing": {
      "$conversationId": {
        ".read": "auth != null",
        ".write": "auth != null",
        "$uid": {
          ".validate": "newData.isString() && newData.val().length <= 50"
        }
      }
    },
    "presence": {
      "$uid": {
        ".read": "$uid === auth.uid || auth.token.email === $uid",
        ".write": "$uid === auth.uid || auth.token.email === $uid",
        ".validate": "newData.hasChildren(['status','lastSeen'])"
      }
    },
    "status": {
      "$userId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "chats": {
      "$chatId": {
        ".read": "auth != null",
        ".write": "auth != null",
        "messages": {
          "$messageId": {
            ".read": "auth != null",
            ".write": "auth != null"
          }
        }
      }
    },
    "user_conversations": {
      "$userId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "groups": {
      "$groupId": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['name','members','createdBy','createdAt'])",
        "members": {
          "$userId": {
            ".read": "auth != null",
            ".write": "auth != null"
          }
        },
        "admins": {
          "$userId": {
            ".read": "auth != null",
            ".write": "auth != null"
          }
        },
        "messages": {
          ".read": "auth != null",
          ".write": "auth != null",
          "$messageId": {
            ".validate": "newData.hasChildren(['senderId','content','timestamp']) && newData.child('senderId').val() === auth.token.email || newData.child('senderId').val() === auth.uid"
          }
        },
        "typing": {
          "$userId": {
            ".write": "auth != null"
          }
        }
      }
    },
    "userGroups": {
      "$userId": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".indexOn": [
          "updatedAt"
        ]
      }
    },
    ".read": false,
    ".write": false
  }
}